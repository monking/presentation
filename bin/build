#!/bin/bash
# version: 0.2.0
# dateModified: 2026-04-02

main() {
  local scriptPath="$(canon "$0")"

  local rootDir="$(cd "$(dirname "$scriptPath")/.."; pwd)"

  local srcDir="$rootDir/src"
  local appDir="$srcDir/presentation"
  local appScriptPaths=("$appDir/presentation.js")
  local appStylePaths=("$appDir/presentation.css")

  local distPath="$rootDir/dist"
  local inplace=false
  local shouldWatch=false
  local fromFormat=markdown

  local OPTIND OPTARG

  while getopts c:df:hij:w flag; do
    case $flag in
      c) appStylePaths+=("$OPTARG");;
      d) inplace=false;;
      f) fromFormat="$OPTARG";;
      h) help_build; exit 0;;
      i) inplace=true;;
      j) appScriptPaths+=("$OPTARG");;
      w) shouldWatch=true;;
    esac
  done
  [[ $OPTIND -gt 1 ]] && shift $((OPTIND - 1))

  local markdownPaths=()

  if [[ ${#@} -gt 0 ]]; then
    markdownPaths=("$@")
  else
    markdownPaths=("$srcDir/"*.md)
  fi

  compile() {
    local markdownPath
    local pandocBaseCommand=(pandoc -f markdown -t html --embed-resources --standalone)
    local headIncludeTempFile="${rootDir}/.tmp-head-include.html"

    {
      echo '<style type="text/css" rel="stylesheet">'"$(cat "${appStylePaths[@]}")"'</style>'
      echo '<script>'"$(cat "${appScriptPaths[@]}")"'</script>'
    } > "$headIncludeTempFile"

    pandocBaseCommand+=(--include-in-header="$headIncludeTempFile")

    for markdownPath in "${markdownPaths[@]}"; do
      local markdownBasename="$(basename "$markdownPath")"
      local outputBasename="${markdownBasename/.md/.present.html}"
      local outputPath

      if [[ $inplace = true ]]; then
        outputPath="$(dirname "$markdownPath")/${outputBasename}"
      else
        outputPath="${distPath}/${outputBasename}"
      fi

      local pandocCommand=("${pandocBaseCommand[@]}")

      pandocCommand+=("$markdownPath")

      "${pandocCommand[@]}" > "$outputPath"
    done
  }

  if [[ $shouldWatch = true ]]; then
    while true; do compile; sleep 2; done # TODO: actually watch for changes, maybe md5sum
  else
    compile
  fi
}

help_build() {
	echo "Turn a markdown file into an interactive HTML presentation."
	echo "OPTIONS"
	echo " -c FILE  Specify a custom CSS file to load after the default."
	echo "          You may load multiple stylesheets by passing -c multiple times"
	echo "          See CUSTOM CSS PROPERTIES toapply a color scheme."
	echo ""
	echo " -j FILE  Specify a custom JavaScript file, to be executed after"
	echo "          the presentation has initialized. You may load multiple"
	echo "          scripts by passing -j multiple times"
	echo ""
	echo "          Note: scripts are concatenated within one <script> tag,"
	echo "          which may cause problems if a script begins with a '(',"
	echo "          or doesn't end with a ';' when it should."
	echo ""
  echo " -d       Output the presentation HTML file in the dist/ directory. (default)"
	echo ""
	echo " -i       Output the presentation HTML file alongside the input file."
	echo ""
  echo " -f FMT   Use input format FMT instead of 'markdown'"
  echo "          (e.g. 'gfm' for GitHub-Flavored Markdown; see pandoc -f)."
	echo ""
	echo " -h       Show this help."
	echo ""
	echo " -w       Watch for changes in the provided files, and rebuild.*"
	echo ""
	echo "DEPENDENCIES"
	echo ""
	echo " pandoc (https://pandoc.org/) is used to turn the markdown file into an HTML file."
	echo ""
	echo "CUSTOM CSS PROPERTIES"
	echo ""
	echo " The default stylesheet contains this rule:"
	echo ""
	echo " :root {"
	echo "   --header-bg-color: teal;"
	echo "   --header-text-color: white;"
	echo "   --header-accent-color: skyblue;"
	echo "   --content-bg-color: #EEE;"
	echo "   --content-text-color: #000;"
	echo "   --em-bg-color: white;"
	echo "   --em-text-color: darkblue;"
	echo " }"
	echo ""
	echo " If you copy this to your custom stylesheet and specify different"
	echo " colors, then they will be applied when you build with -c YOURCSS."
	echo ""
	echo "BROWSER COMPATIBILITY"
	echo ""
	echo " Basically anything escept Internet Explorer is supported."
	echo ""
	echo " The JavaScript driving the presentation uses class and constants, and so"
	echo " requires a browser which supports ECMAScript 2015."
	echo " https://developer.mozilla.org/en-US/docs/Web/JavaScript/Reference/Classes#Browser_compatibility"
	echo ""
	echo " Custom CSS properties are also used."
	echo " https://developer.mozilla.org/en-US/docs/Web/CSS/--*#Browser_compatibility"
	echo ""
	echo "---"
	echo ""
	echo "* Actually, -w causes this script to rebuild the output every 2 seconds,"
	echo "  regardless of whether files have changed."
}

canon() {
	## find the full path of a file or directory, following all symlinks
	local cwd="$PWD"
	for targetFile in "$@"; do
		cd "$cwd"
		cd "$(dirname "$targetFile")"
		local targetFile="$(basename "$targetFile")"

		# Iterate down a (possible) chain of symlinks
		while [ -L "$targetFile" ]
		do
			targetFile="$(readlink "$targetFile")"
			cd "$(dirname "$targetFile")"
			targetFile="$(basename "$targetFile")"
		done

		# Compute the canonicalized name by finding the physical path
		# for the directory we're in and appending the target file.
		local physDir="$(pwd -P)"
		local result=$physDir/
		if [ ! "$targetFile" = "." ]; then
			result="$result$targetFile"
		fi
		if [ -t 1 ]; then
			echo "$result"
		else
			printf "$result"
		fi
	done
}

main "$@"
